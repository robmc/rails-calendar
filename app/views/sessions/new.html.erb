<%= form_tag sessions_path do %>
	<div id="login_container">
		<span id="login_large">Log in</span>&nbsp;&nbsp;|&nbsp;&nbsp;Don't have an account? <%= link_to "Sign up!", "sign_up" %>
		<div id="email_and_remember_me">		
			<div id="email_label"><%= label_tag :email, "Email Address:" %></div>
			<%= text_field_tag :email, params[:email], :placeholder => "example@gmail.com" %>
			<div id="remember_me_field">
				<%= label_tag :remember_me %>
				<%= check_box_tag :remember_me, 1, params[:remember_me] %>
			</div>
		</div>
		<div id="password_and_forgot_password">
			<div id="password_label"><%= label_tag :password, "Password:" %></div>
			<%= password_field_tag :password %>
			<div id="forgot_pass">
				<%= link_to "Forgot your password?", new_password_reset_path %>
			</div>
		</div>
	</div>
	<div id="login_button">
		<p class="button"><%= submit_tag "Log in" %></p>
	</div>
<% end %>